FROM nvcr.io/nvidia/pytorch:24.12-py3

WORKDIR /app

RUN pip install --no-cache-dir \
    diffusers==0.32.2 \
    transformers==4.47.1 \
    accelerate \
    fastapi \
    uvicorn \
    pillow \
    sentencepiece \
    protobuf

COPY image_server.py .

EXPOSE 8888

ENTRYPOINT ["python", "image_server.py"]
CMD ["--model", "black-forest-labs/FLUX.1-schnell", "--port", "8888"]
